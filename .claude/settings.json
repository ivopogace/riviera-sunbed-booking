{
  "enabledMcpjsonServers": ["angular-cli"],
  "permissions": {
    "allow": ["mcp__angular-cli"]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/cloud-session-setup.sh"
          }
        ]
      }
    ]
  }
}
