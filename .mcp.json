{
  "mcpServers": {
    "angular-cli": {
      "command": "npx",
      "args": ["-y", "@angular/cli@22", "mcp"]
    },
    "render": {
      "type": "http",
      "url": "https://mcp.render.com/mcp",
      "headers": { "Authorization": "Bearer ${CLAUDE_RENDER_KEY}" }
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--headless",
        "--no-sandbox",
        "--isolated",
        "--executable-path",
        "/opt/pw-browsers/chromium"
      ]
    }
  }
}
